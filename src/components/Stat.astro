---
interface Props {
  figure: string;
  text: string;
  source: string;
}
const { figure, text, source } = Astro.props;
---

<div class="stat">
  <p class="stat-figure">{figure}</p>
  <p class="stat-text">{text}</p>
  <p class="stat-source">Source · {source}</p>
</div>

<style>
  .stat-figure {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 500;
    font-size: clamp(44px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .stat-text {
    color: var(--muted);
    font-size: 15.5px;
    margin: 0 0 16px;
  }

  .stat-source {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
</style>
