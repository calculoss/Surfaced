---
import { withBase } from '../lib/withBase.js';

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
}
const {
  eyebrow = 'Ready when you are',
  heading = "Let's find out what you're wasting.",
  body = 'One fixed-fee diagnostic, scoped and capped up front. Whatever you decide afterwards, the savings register is yours to keep.',
} = Astro.props;
---

<section class="section cta-section" aria-labelledby="cta-heading">
  <div class="container">
    <div class="dark-panel cta-panel">
      <p class="cta-eyebrow">{eyebrow}</p>
      <h2 id="cta-heading">{heading}</h2>
      <p class="cta-body">{body}</p>
      <a class="btn btn-brass" href={withBase('/contact')}>Book a diagnostic</a>
    </div>
  </div>
</section>

<style>
  .cta-panel {
    text-align: center;
    padding: clamp(56px, 8vw, 90px) clamp(24px, 6vw, 80px);
  }

  .cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brass);
    margin: 0 0 18px;
  }

  .cta-panel h2 {
    color: #fff;
    margin-bottom: 16px;
  }

  .cta-body {
    color: rgba(236, 235, 228, 0.72);
    max-width: 34em;
    margin: 0 auto 32px;
  }
</style>
